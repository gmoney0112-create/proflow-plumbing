{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "jsx": "react",
    "module": "commonjs",
    "moduleResolution": "node",
    "baseUrl": "src",
    "resolveJsonModule": true
  },
  "include": ["src"]
}
